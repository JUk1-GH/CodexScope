{
  "name": "codexscope",
  "version": "0.1.0",
  "description": "A local-first Codex usage and quota dashboard.",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "generate": "go run generate_codex_data.go",
    "generate:py": "python3 generate_codex_data.py",
    "generate:py:win": "py generate_codex_data.py",
    "build:generator": "go build -o codexscope-generator generate_codex_data.go",
    "verify": "node verify_responsive.js"
  },
  "devDependencies": {
    "playwright": "^1.56.0"
  }
}
